# Set correct MIME types for JavaScript modules
/*.js
  Content-Type: application/javascript

/assets/*.js
  Content-Type: application/javascript

/*.mjs
  Content-Type: application/javascript

/assets/*.mjs
  Content-Type: application/javascript

# Ensure service worker is served correctly
/sw.js
  Cache-Control: max-age=0
  Content-Type: application/javascript

# Cache static assets
/icons/*
  Cache-Control: public, max-age=31536000

/sounds/*
  Cache-Control: public, max-age=31536000 